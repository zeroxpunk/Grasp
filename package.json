{
  "name": "grasp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @grasp/web dev",
    "dev:desktop": "pnpm --filter @grasp/desktop dev",
    "dev:backend": "pnpm --filter @grasp/backend dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @grasp/web build",
    "build:desktop": "pnpm --filter @grasp/desktop build",
    "build:backend": "pnpm --filter @grasp/backend build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r exec rm -rf node_modules .next out dist",
    "db:generate": "pnpm --filter @grasp/db db:generate",
    "db:migrate": "pnpm --filter @grasp/db db:migrate",
    "db:push": "pnpm --filter @grasp/db db:push",
    "db:studio": "pnpm --filter @grasp/db db:studio"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
